---
const title = "Sir, this way.";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="整个活。" />
    <title>{title}</title>
  </head>
  <body>
    <canvas id="starfield" aria-hidden="true"></canvas>
    <div class="cosmic-haze" aria-hidden="true"></div>

    <main class="station" aria-label="深空信号控制台">
      <section class="metrics" aria-live="polite">
        <strong id="clickCount">0</strong>
        <span class="metric-copy">signals from</span>
        <strong id="locationCount">0</strong>
        <span class="metric-copy">locations</span>
      </section>

      <section class="globe-stage" aria-label="全球信号位置">
        <canvas id="earthCanvas"></canvas>
        <div class="globe-vignette" aria-hidden="true"></div>
      </section>

      <button id="signalButton" class="signal-button" type="button" aria-label="发送信号">
        <span class="button-core" aria-hidden="true"></span>
      </button>
    </main>

    <script>
      import * as THREE from "three";

      const starCanvas = document.querySelector("#starfield");
      const starContext = starCanvas instanceof HTMLCanvasElement ? starCanvas.getContext("2d") : null;
      const earthCanvas = document.querySelector("#earthCanvas");
      const locationCount = document.querySelector("#locationCount");
      const clickCount = document.querySelector("#clickCount");
      const signalButton = document.querySelector("#signalButton");
      const globeStage = document.querySelector(".globe-stage");

      const numberFormat = new Intl.NumberFormat("zh-CN");
      const stars = [];
      const dust = [];
      const signalBursts = [];
      const signalMeshes = [];
      const cityGlowMeshes = [];
      const cityPoints = [
        [40.7128, -74.006], [34.0522, -118.2437], [37.7749, -122.4194], [19.4326, -99.1332],
        [-23.5505, -46.6333], [-34.6037, -58.3816], [51.5072, -0.1276], [48.8566, 2.3522],
        [52.52, 13.405], [55.7558, 37.6173], [30.0444, 31.2357], [6.5244, 3.3792],
        [-1.2921, 36.8219], [-26.2041, 28.0473], [25.2048, 55.2708], [28.6139, 77.209],
        [13.7563, 100.5018], [1.3521, 103.8198], [31.2304, 121.4737], [39.9042, 116.4074],
        [35.6762, 139.6503], [37.5665, 126.978], [-33.8688, 151.2093], [-37.8136, 144.9631]
      ];
      const EARTH_RADIUS = 1.72;
      const CLOUD_RADIUS = 1.748;
      const ATMOSPHERE_RADIUS = 1.785;
      const CITY_RADIUS = 1.724;
      const SIGNAL_RADIUS = 1.728;
      const BURST_RADIUS = 1.731;

      let width = 0;
      let height = 0;
      let deviceScale = 1;
      let renderer;
      let scene;
      let camera;
      let earthGroup;
      let earthMesh;
      let cloudsMesh;
      let atmosphereMesh;
      let signalGroup;
      let cityGroup;
      let lastFrameTime = 0;
      let globeFocusAnimation = null;
      let autoRotatePausedUntil = 0;

      function setStats(stats) {
        if (locationCount) locationCount.textContent = numberFormat.format(stats.totalLocations ?? 0);
        if (clickCount) clickCount.textContent = numberFormat.format(stats.totalClicks ?? 0);
        renderSignals(Array.isArray(stats.signals) ? stats.signals : [], stats.lastSignalAt);
      }

      async function loadStats() {
        const response = await fetch("/api/signal");
        if (!response.ok) return;
        setStats(await response.json());
      }

      function getCurrentLocation() {
        return new Promise((resolve, reject) => {
          if (!("geolocation" in navigator)) {
            reject(new Error("Geolocation is not available."));
            return;
          }

          navigator.geolocation.getCurrentPosition(
            (position) => {
              resolve({
                accuracy: position.coords.accuracy,
                latitude: position.coords.latitude,
                longitude: position.coords.longitude
              });
            },
            reject,
            {
              enableHighAccuracy: true,
              maximumAge: 60000,
              timeout: 12000
            }
          );
        });
      }

      function latLongToVector3(latitude, longitude, radius) {
        const phi = THREE.MathUtils.degToRad(90 - latitude);
        const theta = THREE.MathUtils.degToRad(longitude + 180);
        return new THREE.Vector3(
          -(radius * Math.sin(phi) * Math.cos(theta)),
          radius * Math.cos(phi),
          radius * Math.sin(phi) * Math.sin(theta)
        );
      }

      function placeOnGlobeSurface(mesh, latitude, longitude, radius) {
        const position = latLongToVector3(latitude, longitude, radius);
        mesh.position.copy(position);
        mesh.quaternion.setFromUnitVectors(new THREE.Vector3(0, 0, 1), position.clone().normalize());
      }

      function forwardAngleDelta(from, to) {
        const fullTurn = Math.PI * 2;
        return ((to - from) % fullTurn + fullTurn) % fullTurn;
      }

      function easeInOutCubic(progress) {
        return progress < 0.5 ? 4 * progress * progress * progress : 1 - Math.pow(-2 * progress + 2, 3) / 2;
      }

      function focusGlobeOnLocation(latitude, longitude) {
        if (!earthGroup) return;

        const localPoint = latLongToVector3(latitude, longitude, 1);
        const tiltedPoint = localPoint.clone().applyAxisAngle(new THREE.Vector3(0, 0, 1), earthGroup.rotation.z);
        const targetRotationY = Math.atan2(-tiltedPoint.x, tiltedPoint.z);
        const startRotationY = earthGroup.rotation.y;
        const deltaRotationY = forwardAngleDelta(startRotationY, targetRotationY);
        const now = performance.now();

        globeFocusAnimation = {
          deltaRotationY,
          duration: 850,
          start: now,
          startRotationY
        };
        autoRotatePausedUntil = now + 2300;
      }

      function createFallbackEarthTexture() {
        const textureWidth = 1024;
        const textureHeight = 512;
        const textureCanvas = document.createElement("canvas");
        const context = textureCanvas.getContext("2d");
        textureCanvas.width = textureWidth;
        textureCanvas.height = textureHeight;

        if (!context) return null;

        const ocean = context.createLinearGradient(0, 0, textureWidth, textureHeight);
        ocean.addColorStop(0, "#1c629d");
        ocean.addColorStop(0.5, "#0b3b74");
        ocean.addColorStop(1, "#021027");
        context.fillStyle = ocean;
        context.fillRect(0, 0, textureWidth, textureHeight);

        context.fillStyle = "rgba(80, 151, 104, 0.9)";
        for (let index = 0; index < 18; index += 1) {
          const x = Math.random() * textureWidth;
          const y = Math.random() * textureHeight;
          const radius = Math.random() * 70 + 34;
          context.beginPath();
          context.ellipse(x, y, radius * 1.6, radius, Math.random() * Math.PI, 0, Math.PI * 2);
          context.fill();
        }

        const texture = new THREE.CanvasTexture(textureCanvas);
        texture.colorSpace = THREE.SRGBColorSpace;
        return texture;
      }

      function loadEarthTexture() {
        const fallbackTexture = createFallbackEarthTexture();
        const loader = new THREE.TextureLoader();
        const texture = loader.load(
          "/textures/earth-blue-marble.png",
          (loadedTexture) => {
            loadedTexture.colorSpace = THREE.SRGBColorSpace;
            loadedTexture.anisotropy = renderer?.capabilities?.getMaxAnisotropy?.() ?? 8;
            loadedTexture.needsUpdate = true;
          },
          undefined,
          () => {
            if (earthMesh?.material) {
              earthMesh.material.map = fallbackTexture;
              earthMesh.material.needsUpdate = true;
            }
          }
        );

        texture.colorSpace = THREE.SRGBColorSpace;
        texture.anisotropy = 8;
        return texture;
      }

      function createCloudTexture() {
        const textureWidth = 1024;
        const textureHeight = 512;
        const textureCanvas = document.createElement("canvas");
        const context = textureCanvas.getContext("2d");
        textureCanvas.width = textureWidth;
        textureCanvas.height = textureHeight;

        if (!context) return null;

        context.clearRect(0, 0, textureWidth, textureHeight);
        for (let index = 0; index < 92; index += 1) {
          const x = Math.random() * textureWidth;
          const y = Math.random() * textureHeight;
          const radiusX = Math.random() * 80 + 34;
          const radiusY = Math.random() * 18 + 8;
          const gradient = context.createRadialGradient(x, y, 0, x, y, radiusX);
          gradient.addColorStop(0, "rgba(255, 255, 255, 0.28)");
          gradient.addColorStop(0.55, "rgba(190, 220, 255, 0.11)");
          gradient.addColorStop(1, "rgba(255, 255, 255, 0)");
          context.fillStyle = gradient;
          context.save();
          context.translate(x, y);
          context.scale(1, radiusY / radiusX);
          context.beginPath();
          context.arc(0, 0, radiusX, 0, Math.PI * 2);
          context.fill();
          context.restore();
        }

        return new THREE.CanvasTexture(textureCanvas);
      }

      function createSpriteTexture(color, core = "#fff4ba") {
        const size = 128;
        const textureCanvas = document.createElement("canvas");
        const context = textureCanvas.getContext("2d");
        textureCanvas.width = size;
        textureCanvas.height = size;

        if (!context) return null;

        const gradient = context.createRadialGradient(size / 2, size / 2, 0, size / 2, size / 2, size / 2);
        gradient.addColorStop(0, core);
        gradient.addColorStop(0.16, color);
        gradient.addColorStop(0.38, color.replace("1)", "0.38)"));
        gradient.addColorStop(1, color.replace("1)", "0)"));
        context.fillStyle = gradient;
        context.beginPath();
        context.arc(size / 2, size / 2, size / 2, 0, Math.PI * 2);
        context.fill();

        const texture = new THREE.CanvasTexture(textureCanvas);
        texture.colorSpace = THREE.SRGBColorSpace;
        return texture;
      }

      function createSurfaceGlow(latitude, longitude, radius, size, material, baseScale, phase = 0) {
        const glow = new THREE.Mesh(new THREE.PlaneGeometry(size, size), material);
        placeOnGlobeSurface(glow, latitude, longitude, radius);
        glow.userData.baseScale = baseScale;
        glow.userData.baseOpacity = material.opacity;
        glow.userData.phase = phase;
        glow.userData.surfaceGlow = true;
        return glow;
      }

      function initEarth() {
        if (!(earthCanvas instanceof HTMLCanvasElement)) return;

        renderer = new THREE.WebGLRenderer({
          alpha: true,
          antialias: true,
          canvas: earthCanvas,
          powerPreference: "high-performance"
        });
        renderer.setClearColor(0x000000, 0);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
        renderer.outputColorSpace = THREE.SRGBColorSpace;

        scene = new THREE.Scene();
        camera = new THREE.PerspectiveCamera(34, 1, 0.1, 100);
        camera.position.set(0, 0.04, 6.35);

        earthGroup = new THREE.Group();
        earthGroup.rotation.y = THREE.MathUtils.degToRad(-86);
        earthGroup.rotation.z = THREE.MathUtils.degToRad(-12);
        scene.add(earthGroup);

        const earthTexture = loadEarthTexture();
        const earthGeometry = new THREE.SphereGeometry(EARTH_RADIUS, 128, 128);
        const earthMaterial = new THREE.MeshStandardMaterial({
          map: earthTexture,
          metalness: 0.02,
          roughness: 0.92
        });
        earthMesh = new THREE.Mesh(earthGeometry, earthMaterial);
        earthGroup.add(earthMesh);

        const cloudsTexture = createCloudTexture();
        cloudsMesh = new THREE.Mesh(
          new THREE.SphereGeometry(CLOUD_RADIUS, 128, 128),
          new THREE.MeshBasicMaterial({
            map: cloudsTexture,
            opacity: 0.26,
            transparent: true,
            blending: THREE.AdditiveBlending,
            depthWrite: false
          })
        );
        earthGroup.add(cloudsMesh);

        atmosphereMesh = new THREE.Mesh(
          new THREE.SphereGeometry(ATMOSPHERE_RADIUS, 128, 128),
          new THREE.MeshBasicMaterial({
            color: 0x54c7ff,
            opacity: 0.065,
            transparent: true,
            blending: THREE.AdditiveBlending,
            side: THREE.BackSide
          })
        );
        earthGroup.add(atmosphereMesh);

        signalGroup = new THREE.Group();
        earthGroup.add(signalGroup);

        cityGroup = new THREE.Group();
        const cityCoreGeometry = new THREE.CircleGeometry(0.012, 18);
        const cityCoreMaterial = new THREE.MeshBasicMaterial({
          color: 0xffb15b,
          opacity: 0.92,
          transparent: true,
          blending: THREE.AdditiveBlending,
          depthTest: true,
          depthWrite: false,
          side: THREE.DoubleSide
        });
        const cityGlowTexture = createSpriteTexture("rgba(255, 163, 66, 1)");
        const cityGlowMaterial = new THREE.MeshBasicMaterial({
          map: cityGlowTexture,
          opacity: 0.42,
          transparent: true,
          blending: THREE.AdditiveBlending,
          depthTest: true,
          depthWrite: false,
          side: THREE.DoubleSide
        });
        for (const [latitude, longitude] of cityPoints) {
          const cityGlow = createSurfaceGlow(
            latitude,
            longitude,
            CITY_RADIUS + 0.001,
            0.108,
            cityGlowMaterial,
            1,
            Math.random() * Math.PI * 2
          );
          const cityCore = new THREE.Mesh(cityCoreGeometry, cityCoreMaterial);
          placeOnGlobeSurface(cityCore, latitude, longitude, CITY_RADIUS + 0.002);
          cityGroup.add(cityGlow, cityCore);
          cityGlowMeshes.push(cityGlow);
        }
        earthGroup.add(cityGroup);

        scene.add(new THREE.AmbientLight(0x426fa9, 0.62));
        const keyLight = new THREE.DirectionalLight(0xffffff, 3.45);
        keyLight.position.set(-3.9, 2.45, 5.4);
        scene.add(keyLight);
        const rimLight = new THREE.DirectionalLight(0x46b7ff, 1.9);
        rimLight.position.set(3.8, 0.8, -3.6);
        scene.add(rimLight);

        resizeEarth();
      }

      function renderSignals(signals, lastSignalAt) {
        if (!signalGroup) return;

        signalGroup.clear();
        signalMeshes.length = 0;

        const signalCoreGeometry = new THREE.CircleGeometry(0.018, 24);
        const signalGlowTexture = createSpriteTexture("rgba(255, 47, 37, 1)");
        for (const signal of signals) {
          if (
            typeof signal.latitude !== "number" ||
            typeof signal.longitude !== "number" ||
            !Number.isFinite(signal.latitude) ||
            !Number.isFinite(signal.longitude)
          ) {
            continue;
          }

          const count = Number.isFinite(signal.signalCount) ? signal.signalCount : 1;
          const baseScale = Math.min(1.85, 0.86 + Math.log(count + 1) * 0.18);
          const glow = createSurfaceGlow(
            signal.latitude,
            signal.longitude,
            SIGNAL_RADIUS,
            0.19,
            new THREE.MeshBasicMaterial({
              map: signalGlowTexture,
              opacity: signal.lastSignalAt === lastSignalAt ? 0.72 : 0.48,
              transparent: true,
              blending: THREE.AdditiveBlending,
              depthTest: true,
              depthWrite: false,
              side: THREE.DoubleSide
            }),
            baseScale,
            Math.random() * Math.PI * 2
          );
          glow.userData.recent = signal.lastSignalAt === lastSignalAt;
          glow.userData.startedAt = performance.now();

          const core = new THREE.Mesh(
            signalCoreGeometry,
            new THREE.MeshBasicMaterial({
              color: 0xffd59b,
              opacity: 0.9,
              transparent: true,
              blending: THREE.AdditiveBlending,
              depthTest: true,
              depthWrite: false,
              side: THREE.DoubleSide
            })
          );
          placeOnGlobeSurface(core, signal.latitude, signal.longitude, SIGNAL_RADIUS + 0.002);
          core.scale.setScalar(Math.min(1.35, 0.72 + Math.log(count + 1) * 0.12));
          signalGroup.add(glow, core);
          signalMeshes.push(glow);

          if (signal.lastSignalAt === lastSignalAt) {
            addGlobeBurst(signal.latitude, signal.longitude);
          }
        }
      }

      function addGlobeBurst(latitude, longitude) {
        if (!signalGroup) return;

        const position = latLongToVector3(latitude, longitude, BURST_RADIUS);
        const ring = new THREE.Mesh(
          new THREE.RingGeometry(0.04, 0.055, 48),
          new THREE.MeshBasicMaterial({
            color: 0xff3328,
            transparent: true,
            opacity: 0.82,
            blending: THREE.AdditiveBlending,
            depthWrite: false,
            side: THREE.DoubleSide
          })
        );
        placeOnGlobeSurface(ring, latitude, longitude, BURST_RADIUS);
        ring.userData.startedAt = performance.now();
        ring.userData.burst = true;
        signalGroup.add(ring);
        signalMeshes.push(ring);
      }

      function resizeEarth() {
        if (!renderer || !camera || !(globeStage instanceof HTMLElement)) return;

        const rect = globeStage.getBoundingClientRect();
        const renderWidth = Math.max(1, Math.floor(rect.width));
        const renderHeight = Math.max(1, Math.floor(rect.height));
        renderer.setSize(renderWidth, renderHeight, false);
        camera.aspect = renderWidth / renderHeight;
        camera.position.z = renderWidth < 520 ? 6.62 : 6.36;
        camera.updateProjectionMatrix();
      }

      function updateEarth(now) {
        if (!renderer || !scene || !camera || !earthGroup) return;

        const delta = lastFrameTime ? Math.min(40, now - lastFrameTime) : 16.7;
        lastFrameTime = now;

        if (globeFocusAnimation) {
          const progress = Math.min(1, (now - globeFocusAnimation.start) / globeFocusAnimation.duration);
          earthGroup.rotation.y =
            globeFocusAnimation.startRotationY + globeFocusAnimation.deltaRotationY * easeInOutCubic(progress);
          if (progress >= 1) globeFocusAnimation = null;
        } else if (now > autoRotatePausedUntil) {
          earthGroup.rotation.y += delta * 0.00008;
        }
        if (cloudsMesh) cloudsMesh.rotation.y += delta * 0.000035;
        if (atmosphereMesh) atmosphereMesh.rotation.y -= delta * 0.00002;

        for (const glow of cityGlowMeshes) {
          const wave = Math.sin(now * 0.0028 + glow.userData.phase) * 0.16 + 1;
          glow.scale.setScalar(glow.userData.baseScale * wave);
          glow.material.opacity = glow.userData.baseOpacity * (0.78 + (wave - 1) * 1.1);
        }

        for (let index = signalMeshes.length - 1; index >= 0; index -= 1) {
          const mesh = signalMeshes[index];

          if (mesh.userData.surfaceGlow) {
            const pulse = Math.sin(now * 0.004 + mesh.userData.phase) * 0.2 + 1;
            const recentBoost = mesh.userData.recent ? Math.max(0, 1 - (now - mesh.userData.startedAt) / 1800) : 0;
            mesh.scale.setScalar(mesh.userData.baseScale * (pulse + recentBoost * 0.95));
            mesh.material.opacity = mesh.userData.baseOpacity * (0.72 + (pulse - 1) * 0.9 + recentBoost * 0.7);
            continue;
          }

          const progress = (now - mesh.userData.startedAt) / 1700;
          if (progress >= 1) {
            mesh.parent?.remove(mesh);
            signalMeshes.splice(index, 1);
            continue;
          }

          mesh.scale.setScalar(1 + progress * 10);
          mesh.material.opacity = Math.max(0, 0.72 * (1 - progress));
        }

        renderer.render(scene, camera);
      }

      function addViewportSignalBurst() {
        if (!(globeStage instanceof HTMLElement)) return;

        const rect = globeStage.getBoundingClientRect();
        signalBursts.push({
          start: performance.now(),
          x: rect.left + rect.width / 2,
          y: rect.top + rect.height * 0.55
        });
      }

      async function sendSignal() {
        if (!(signalButton instanceof HTMLButtonElement)) return;

        signalButton.disabled = true;
        document.body.classList.add("is-locating");

        try {
          const location = await getCurrentLocation();

          document.body.classList.remove("is-locating");
          document.body.classList.add("is-signaling");
          focusGlobeOnLocation(location.latitude, location.longitude);
          globeStage?.classList.remove("bursting");
          window.requestAnimationFrame(() => globeStage?.classList.add("bursting"));
          addViewportSignalBurst();

          const response = await fetch("/api/signal", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              accuracy: location.accuracy,
              latitude: location.latitude,
              longitude: location.longitude
            })
          });

          if (response.ok) {
            setStats(await response.json());
          }
        } catch {
          document.body.classList.add("location-failed");
        } finally {
          window.setTimeout(() => {
            signalButton.disabled = false;
            document.body.classList.remove("is-locating", "location-failed");
            document.body.classList.remove("is-signaling");
          }, 820);
        }
      }

      function resizeCanvas() {
        if (!starCanvas || !starContext) return;

        deviceScale = Math.min(window.devicePixelRatio || 1, 2);
        width = window.innerWidth;
        height = window.innerHeight;
        starCanvas.width = Math.floor(width * deviceScale);
        starCanvas.height = Math.floor(height * deviceScale);
        starCanvas.style.width = `${width}px`;
        starCanvas.style.height = `${height}px`;
        starContext.setTransform(deviceScale, 0, 0, deviceScale, 0, 0);

        const starCount = Math.round(Math.min(900, Math.max(280, (width * height) / 3100)));
        const dustCount = Math.round(Math.min(150, Math.max(48, (width * height) / 15000)));
        stars.length = 0;
        dust.length = 0;

        for (let index = 0; index < starCount; index += 1) {
          const colorRoll = Math.random();
          stars.push({
            x: Math.random() * width,
            y: Math.random() * height,
            radius: Math.random() * 1.8 + 0.16,
            alpha: Math.random() * 0.72 + 0.2,
            speed: Math.random() * 0.16 + 0.014,
            drift: Math.random() * 0.1 - 0.05,
            color:
              colorRoll > 0.9
                ? "255, 146, 211"
                : colorRoll > 0.72
                  ? "114, 232, 255"
                  : colorRoll > 0.56
                    ? "255, 231, 148"
                    : "236, 248, 255"
          });
        }

        for (let index = 0; index < dustCount; index += 1) {
          dust.push({
            x: Math.random() * width,
            y: Math.random() * height,
            length: Math.random() * 96 + 38,
            alpha: Math.random() * 0.2 + 0.04,
            speed: Math.random() * 0.08 + 0.018,
            angle: -0.72 + Math.random() * 0.18
          });
        }

        resizeEarth();
      }

      function drawSignalBursts(now) {
        if (!starContext) return;

        for (let index = signalBursts.length - 1; index >= 0; index -= 1) {
          const burst = signalBursts[index];
          const progress = (now - burst.start) / 1850;

          if (progress >= 1) {
            signalBursts.splice(index, 1);
            continue;
          }

          const beamHeight = height * (0.48 + progress * 0.74);
          const glow = 1 - progress;
          const gradient = starContext.createLinearGradient(burst.x, burst.y, burst.x, burst.y - beamHeight);
          gradient.addColorStop(0, `rgba(255, 35, 30, ${0.44 * glow})`);
          gradient.addColorStop(0.2, `rgba(255, 195, 90, ${0.36 * glow})`);
          gradient.addColorStop(0.62, `rgba(108, 232, 255, ${0.22 * glow})`);
          gradient.addColorStop(1, "rgba(255, 42, 42, 0)");

          starContext.save();
          starContext.globalCompositeOperation = "screen";
          starContext.strokeStyle = gradient;
          starContext.lineWidth = 18 + 58 * progress;
          starContext.beginPath();
          starContext.moveTo(burst.x, burst.y);
          starContext.lineTo(burst.x + Math.sin(progress * Math.PI * 2) * 26, burst.y - beamHeight);
          starContext.stroke();

          starContext.strokeStyle = `rgba(255, 64, 58, ${0.34 * glow})`;
          starContext.lineWidth = 2;
          starContext.beginPath();
          starContext.arc(burst.x, burst.y, 80 + progress * 460, 0, Math.PI * 2);
          starContext.stroke();
          starContext.restore();
        }
      }

      function animate(now) {
        if (!starContext) return;

        starContext.clearRect(0, 0, width, height);

        starContext.save();
        starContext.globalCompositeOperation = "screen";

        for (const particle of dust) {
          particle.x += Math.cos(particle.angle) * particle.speed;
          particle.y += Math.sin(particle.angle) * particle.speed;

          if (particle.x < -particle.length) particle.x = width + particle.length;
          if (particle.y < -particle.length) particle.y = height + particle.length;

          const endX = particle.x + Math.cos(particle.angle) * particle.length;
          const endY = particle.y + Math.sin(particle.angle) * particle.length;
          const dustGradient = starContext.createLinearGradient(particle.x, particle.y, endX, endY);
          dustGradient.addColorStop(0, "rgba(255, 255, 255, 0)");
          dustGradient.addColorStop(0.45, `rgba(151, 236, 255, ${particle.alpha})`);
          dustGradient.addColorStop(1, "rgba(255, 255, 255, 0)");

          starContext.strokeStyle = dustGradient;
          starContext.lineWidth = 1;
          starContext.beginPath();
          starContext.moveTo(particle.x, particle.y);
          starContext.lineTo(endX, endY);
          starContext.stroke();
        }

        for (const star of stars) {
          star.y += star.speed;
          star.x += star.drift;

          if (star.y > height + 4) star.y = -4;
          if (star.x < -4) star.x = width + 4;
          if (star.x > width + 4) star.x = -4;

          const twinkle = Math.sin(now * 0.0015 + star.x) * 0.2 + 0.8;
          starContext.fillStyle = `rgba(${star.color}, ${star.alpha * twinkle})`;
          starContext.beginPath();
          starContext.arc(star.x, star.y, star.radius, 0, Math.PI * 2);
          starContext.fill();
        }

        drawSignalBursts(now);
        starContext.restore();
        updateEarth(now);
        window.requestAnimationFrame(animate);
      }

      window.addEventListener("resize", resizeCanvas);
      signalButton?.addEventListener("click", sendSignal);
      initEarth();
      resizeCanvas();
      loadStats();
      window.requestAnimationFrame(animate);
    </script>
  </body>
</html>

