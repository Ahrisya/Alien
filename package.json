{
  "name": "alien-signal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "pnpm build && wrangler dev --config dist/server/wrangler.json",
    "deploy": "pnpm build && wrangler deploy --config dist/server/wrangler.json",
    "db:migrate": "wrangler d1 migrations apply alien-signal --local",
    "db:migrate:remote": "wrangler d1 migrations apply alien-signal --remote"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.6.1",
    "astro": "latest",
    "three": "^0.184.0",
    "wrangler": "^4.98.0"
  },
  "devDependencies": {
    "typescript": "latest"
  },
  "packageManager": "pnpm@10.7.0"
}
